# Clerk (dashboard.clerk.com -> API keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Supabase Postgres (Project -> Connect)
# Runtime: TRANSACTION pooler, port 6543 (used by src/db/index.ts with prepare:false)
DATABASE_URL=postgres://postgres.[ref]:[PASSWORD]@aws-[region].pooler.supabase.com:6543/postgres
# Migrations: DIRECT or SESSION pooler, port 5432 (used by drizzle.config.ts)
DATABASE_URL_DIRECT=postgres://postgres.[ref]:[PASSWORD]@aws-[region].pooler.supabase.com:5432/postgres

# wger exercise API (optional — defaults to the public instance, no API key required)
# Override only to point at a self-hosted wger. Used by src/lib/wger.ts.
WGER_API_BASE_URL=https://wger.de/api/v2
# wger API key (optional — needed ONLY for the /programs/templates browse+import
# surface: wger's routine endpoints require token auth even for PUBLIC templates,
# unlike its exercise catalog). Any free wger.de account's key works
# (wger.de -> settings -> API). Unset = templates page shows a "not configured"
# empty state; exercise search is unaffected. Used by src/lib/wger-templates.ts.
WGER_API_KEY=

# Upstash Redis (optional — caches the wger exercise catalog for fast search).
# console.upstash.com -> your database -> REST API. Used by src/lib/redis.ts.
# When unset, the app falls back to fetching the catalog directly from wger.
UPSTASH_REDIS_REST_URL=https://[name].upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# Target userId for unauthenticated MCP tool calls (POC). When set, MCP tools
# (e.g. "add my workout") need no userId argument. Use a real Clerk user id.
MCP_DEV_USER_ID=

# Coach dev gate — comma-separated Clerk user ids allowed to use the coach.
# Absent, falls back to MCP_DEV_USER_ID; nothing configured = nobody.
COACH_ALLOWED_USER_IDS=
# AI coach (/api/chat) — provider-agnostic; see src/lib/coach/model.ts.
# Configure EITHER (or both — OpenRouter wins when both are set):
# OpenRouter (prepaid credits): https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Vercel AI Gateway. On Vercel, OIDC covers auth and the key is optional;
# elsewhere it is required. https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=
# Optional: force one provider when several are configured
# ('openrouter' | 'vercel-gateway').
COACH_PROVIDER=
# Optional model override (vendor/model slug, same format on both providers).
# Defaults to anthropic/claude-sonnet-4.5.
COACH_MODEL=
